---
layout: feed
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

	<title> Nidhal Saïdani's Blog </title>
	<link href="http://nidhalsaidani.github.io/blog/atom.xml" rel="self"/>
	<link href="http://nidhalsadaini.github.io/blog"/>
	<updated>{{ site.time | date_to_xmlschema }}</updated>
	<id>http://nidhalsaidani.github.io/blog</id>
	<author>
		<name>Nidhal Saïdani</name>
		<email>contact@nidhalsadiani.com</email>
	</author>

	{% for post in site.posts %}
		<entry>
			<title>{{ post.title }}</title>
			<link href="http://nidhalsadiani.github.io{{ post.url }}"/>
			<updated>{{ post.date | date_to_xmlschema }}</updated>
			<id>http://nidhalsadiani.github.io{{ post.id }}</id>
			<content type="html">{{ post.content | xml_escape }}</content>
		</entry>
	{% endfor %}

</feed>
