---
import Layout from '../layouts/Layout.astro';
import siteConfig from '../config';
import { getCollection } from 'astro:content';
import { sortByDate } from '../lib/utils';

const { name, tagline, bio, research_interests, photo } = siteConfig.home;

// Get latest blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts.sort(sortByDate).slice(0, 3);

// Get featured projects
const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter(({ data }) => data.featured).slice(0, 3);

// Get featured publications
const allPublications = await getCollection('publications');
const featuredPublications = allPublications.filter(({ data }) => data.featured).slice(0, 3);
---

<Layout title="Home" description={tagline}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-50 to-white dark:from-dark-card dark:to-dark-bg -z-10"></div>
    
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div class="space-y-6">
          <div>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold font-serif text-gray-900 dark:text-gray-100 mb-4">
              {name}
            </h1>
            <p class="text-xl sm:text-2xl text-primary-600 dark:text-primary-400 font-medium">
              {tagline}
            </p>
          </div>
          
          <div class="prose prose-lg dark:prose-invert">
            {bio}
          </div>
          
          <!-- Research Interests -->
          <div class="flex flex-wrap gap-2 pt-4">
            {research_interests.map((interest) => (
              <span class="px-4 py-2 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-full text-sm font-medium">
                {interest}
              </span>
            ))}
          </div>
          
          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-4 pt-6">
            <a href="/about/" class="btn-primary">
              More About Me
            </a>
            <a href="/publications/" class="btn-secondary">
              View Publications
            </a>
            <a href={siteConfig.site.social.linkedin} target="_blank" rel="noopener noreferrer" class="btn-secondary">
              Contact
            </a>
          </div>
        </div>
        
        <!-- Profile Image -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute inset-0 bg-primary-200 dark:bg-primary-800 rounded-full blur-3xl opacity-30 animate-pulse"></div>
            <div class="relative w-64 h-64 sm:w-80 sm:h-80 lg:w-96 lg:h-96 rounded-full overflow-hidden border-4 border-white dark:border-dark-card shadow-2xl">
              <img
                src={photo}
                alt={name}
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Latest Blog Posts -->
  {latestPosts.length > 0 && (
    <section class="py-16 bg-white dark:bg-dark-bg">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center mb-8">
          <h2 class="text-3xl font-bold font-serif text-gray-900 dark:text-gray-100">
            Latest Posts
          </h2>
          <a href="/blog/" class="text-primary-600 dark:text-primary-400 hover:underline font-medium">
            View all →
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <article class="card">
              <a href={`/blog/${post.slug}/`}>
                {post.data.heroImage && (
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-48 object-cover rounded-lg mb-4"
                  />
                )}
                <h3 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-2 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                  {post.data.title}