---
import Layout from '../../layouts/Layout.astro';
import { readingTime, formatDate } from '../../lib/utils';

const { Content } = await render(Astro.props.post);
const post = Astro.props.post;
const minutes = readingTime(post.body);
---

<Layout title={post.data.title} description={post.data.description || ''}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-8">
      <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400 mb-4">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        <span>·</span>
        <span>{minutes} min read</span>
      </div>
      
      <h1 class="text-4xl font-bold font-serif text-gray-900 dark:text-gray-100 mb-4">
        {post.data.title}
      </h1>
      
      {post.data.description && (
        <p class="text-xl text-gray-600 dark:text-gray-400">
          {post.data.description}
        </p>
      )}
      
      {post.data.heroImage && (
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          class="w-full h-96 object-cover rounded-xl mt-6"
        />
      )}
    </header>
    
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>
    
    {post.data.tags && post.data.tags.length > 0 && (
      <div class="mt-12 pt-8 border-t border-gray-200 dark:border-dark-border">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="px-3 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-full text-sm">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>
